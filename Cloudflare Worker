export default {
  async fetch(request, env, ctx) {
    try {
      // 1. Fetch from the official UPMA API endpoint
      const response = await fetch("https://api.upma.org/api/public/rates", {
        headers: {
          "Accept": "application/json",
          "User-Agent": "Goldback-Retail-POS/1.0"
        }
      });
      
      const data = await response.json();
      
      // 2. Grab the exact keys Goldback provided
      // We will use the "retail rate" as the primary rate for the POS.
      let retailPrice = data.goldback_rate ? parseFloat(data.goldback_rate).toFixed(2) : "0.00";
      let officialPrice = data.goldback_official_price ? parseFloat(data.goldback_official_price).toFixed(2) : "0.00";

      // 3. Return the clean, highly accurate response to your POS app
      return new Response(JSON.stringify({ 
        rate: retailPrice, 
        official_base_rate: officialPrice, // Included just for your own records/curiosity
        source: "Official UPMA API"
      }), {
        headers: {
          "content-type": "application/json",
          "Access-Control-Allow-Origin": "*",
          "Access-Control-Allow-Methods": "GET, OPTIONS"
        }
      });

    } catch (e) {
      return new Response(JSON.stringify({ rate: "0.00", source: "API Error", debug: e.message }), {
        headers: { 
            "content-type": "application/json", 
            "Access-Control-Allow-Origin": "*" 
        }
      });
    }
  }
};
