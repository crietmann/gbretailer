eexport default {
  async fetch(request, env, ctx) {
    try {
      // 1. Fetch from the official UPMA API endpoint
      const response = await fetch("https://api.upma.org/api/public/rates", {
        headers: {
          // Tell the server we specifically want raw data, and introduce our app
          "Accept": "application/json",
          "User-Agent": "Goldback-Retail-POS/1.0"
        }
      });
      
      const data = await response.json();
      
      // 2. Since we haven't seen their exact JSON structure yet, we'll turn the 
      // data into a text string and use a smart search to grab the Goldback rate.
      const jsonString = JSON.stringify(data).toLowerCase();
      let price = "0.00";
      
      // Search for "goldback", then scan forward for the first decimal number
      const match = jsonString.match(/goldback.*?([0-9]+\.[0-9]{2,4})/);
      
      if (match && match[1]) {
        price = parseFloat(match[1]).toFixed(2);
      }

      // 3. Return the clean response to your POS app
      return new Response(JSON.stringify({ 
        rate: price,
        source: "Official UPMA API",
        // If the price is 0.00, we send the raw API data to the debug log so we can see their exact formatting!
        debug: price === "0.00" ? "Raw JSON: " + jsonString.substring(0, 300) : "Success"
      }), {
        headers: {
          "content-type": "application/json",
          "Access-Control-Allow-Origin": "*",
          "Access-Control-Allow-Methods": "GET, OPTIONS"
        }
      });

    } catch (e) {
      return new Response(JSON.stringify({ rate: "0.00", source: "API Error", debug: e.message }), {
        headers: { 
            "content-type": "application/json", 
            "Access-Control-Allow-Origin": "*" 
        }
      });
    }
  }
};
